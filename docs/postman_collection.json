          "name": "POST create recipe",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-user-role", "value": "nutritionist" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"סלט ירקות טרי\",\n  \"description\": \"סלט ירקות פשוט וטעים\",\n  \"mealType\": \"lunch\",\n  \"calories\": 200,\n  \"protein\": 5,\n  \"carbs\": 25,\n  \"fat\": 8,\n  \"isVegetarian\": true,\n  \"allergens\": [],\n  \"prepTime\": 10\n}"
            },
            "url": { "raw": "http://localhost:3000/recipes", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["recipes"] }
          }
        },
        {
          "name": "POST create recipe - validation error (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-user-role", "value": "nutritionist" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mealType\": \"lunch\",\n  \"calories\": 200,\n  \"protein\": 5,\n  \"carbs\": 25,\n  \"fat\": 8\n}"
            },
            "url": { "raw": "http://localhost:3000/recipes", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["recipes"] }
          }
        },
        {
