            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"שקשוקה ברוטב חריף\",\n  \"description\": \"שקשוקה ביתית עם פלפלים חריפים\",\n  \"mealType\": \"breakfast\",\n  \"calories\": 420,\n  \"protein\": 24,\n  \"carbs\": 38,\n  \"fat\": 16,\n  \"isVegetarian\": true,\n  \"allergens\": [\"eggs\"],\n  \"prepTime\": 25\n}"
            },
            "url": { "raw": "http://localhost:3000/recipes/2", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["recipes", "2"] }
          }
        },
        {
          "name": "DELETE recipe",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "x-user-role", "value": "admin" }],
            "url": { "raw": "http://localhost:3000/recipes/6", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["recipes", "6"] }
          }
        },
        {
          "name": "DELETE recipe - forbidden (403)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "x-user-role", "value": "nutritionist" }],
            "url": { "raw": "http://localhost:3000/recipes/5", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["recipes", "5"] }
          }
