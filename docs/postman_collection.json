{
  "info": {
    "name": "Nutrition Planning API",
    "description": "Backend API for Smart Nutrition Planning System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "GET all users",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-role", "value": "admin" }],
            "url": { "raw": "http://localhost:3000/users", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users"] }
          }
        },
        {
          "name": "GET user by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-role", "value": "admin" }],
            "url": { "raw": "http://localhost:3000/users/1", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users", "1"] }
          }
        },
        {
          "name": "GET user not found (404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-role", "value": "admin" }],
            "url": { "raw": "http://localhost:3000/users/999", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users", "999"] }
          }
        },
        {
          "name": "POST create user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-user-role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Oren\",\n  \"lastName\": \"Katz\",\n  \"userRole\": \"user\"\n}"
            },
            "url": { "raw": "http://localhost:3000/users", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users"] }
          }
        },
        {
          "name": "POST create user - validation error (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-user-role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lastName\": \"Katz\",\n  \"userRole\": \"user\"\n}"
            },
            "url": { "raw": "http://localhost:3000/users", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users"] }
          }
        },
        {
          "name": "PUT update user",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "x-user-role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Dana\",\n  \"lastName\": \"Ben-Ami\",\n  \"userRole\": \"nutritionist\"\n}"
            },
            "url": { "raw": "http://localhost:3000/users/3", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users", "3"] }
          }
        },
        {
          "name": "DELETE user",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "x-user-role", "value": "admin" }],
            "url": { "raw": "http://localhost:3000/users/5", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users", "5"] }
          }
        },
        {
          "name": "DELETE user - forbidden (403)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "x-user-role", "value": "nutritionist" }],
            "url": { "raw": "http://localhost:3000/users/4", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users", "4"] }
          }
        }
      ]
    },
    {
      "name": "Recipes",
      "item": [
        {
          "name": "GET all recipes",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-role", "value": "user" }],
            "url": { "raw": "http://localhost:3000/recipes", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["recipes"] }
          }
        },
        {
          "name": "GET recipes filter by mealType",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-role", "value": "user" }],
            "url": {
              "raw": "http://localhost:3000/recipes?mealType=breakfast",
              "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["recipes"],
              "query": [{ "key": "mealType", "value": "breakfast" }]
            }
          }
        },
        {
          "name": "GET recipes filter vegetarian",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-role", "value": "user" }],
            "url": {
              "raw": "http://localhost:3000/recipes?isVegetarian=true",
              "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["recipes"],
              "query": [{ "key": "isVegetarian", "value": "true" }]
            }
          }
        },
        {
          "name": "GET recipe by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-role", "value": "user" }],
            "url": { "raw": "http://localhost:3000/recipes/1", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["recipes", "1"] }
